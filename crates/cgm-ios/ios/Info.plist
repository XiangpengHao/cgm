<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Permission/usage strings the app needs. iOS terminates the app if it calls
  CoreBluetooth or HealthKit without the matching key. Merge these into the
  app's Info.plist (dx can do this via [bundle.ios].info_plist_extra; otherwise
  paste into the Xcode target's Info.plist).
-->
<plist version="1.0">
<dict>
    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>This app reads your glucose sensor over Bluetooth.</string>

    <key>NSHealthUpdateUsageDescription</key>
    <string>This app saves your glucose readings to Apple Health.</string>

    <key>NSHealthShareUsageDescription</key>
    <string>This app reads previously saved glucose readings from Apple Health.</string>

    <!-- Make exported backups visible/editable in the Files app. -->
    <key>UIFileSharingEnabled</key>
    <true/>
    <key>LSSupportsOpeningDocumentsInPlace</key>
    <true/>
</dict>
</plist>
